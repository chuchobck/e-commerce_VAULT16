  detalle_ajuste    detalle_ajuste[]
  detalle_factura   detalle_factura[]
  movimiento_stock  movimiento_stock[]
  producto          producto           @relation(fields: [id_producto], references: [id_producto], onDelete: Cascade, map: "fk_var_producto")
  talla             talla              @relation(fields: [id_talla], references: [id_talla], map: "fk_var_talla")

  @@unique([id_producto, id_talla, color], map: "uq_var_combinacion")
  @@index([id_producto], map: "idx_variante_producto")
  @@schema("vortex")
}
