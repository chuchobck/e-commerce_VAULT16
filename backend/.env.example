# ─── SERVER ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── DATABASE ─────────────────────────────────────────────
# REQUERIDA — PostgreSQL 16 con extensiones vector + pgcrypto, schema vortex
DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=disable

# ─── JWT ──────────────────────────────────────────────────
# REQUERIDA — cambiar en producción por una cadena aleatoria segura
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5000
FRONTEND_URL=http://localhost:5000

# ─── ANTHROPIC (opcional) ─────────────────────────────────
# Si está vacía, ai-content y assistant funcionan en modo stub
ANTHROPIC_API_KEY=

# ─── VOYAGE AI (opcional) ─────────────────────────────────
# Si está vacía, los embeddings se saltan (búsqueda semántica desactivada)
VOYAGE_API_KEY=

# ─── AZURE BLOB STORAGE (opcional) ───────────────────────
# Si está vacía, las fotos de productos no se suben (modo stub)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=vortex-productos

# ─── PAYPAL (opcional) ────────────────────────────────────
# Si alguna está vacía, los pagos PayPal funcionan en modo STUB (no se cobra).
# Sandbox: https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
