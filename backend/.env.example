# ─── SERVER ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── DATABASE ─────────────────────────────────────────────
# REQUERIDA — Supabase PostgreSQL 16 connection string
DATABASE_URL=postgresql://user:password@host:5432/db?schema=vortex

# ─── JWT ──────────────────────────────────────────────────
# REQUERIDA — cambiar en producción por una cadena aleatoria segura
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ─── ANTHROPIC (opcional) ─────────────────────────────────
# Si está vacía, ai-content y assistant funcionan en modo stub
ANTHROPIC_API_KEY=

# ─── VOYAGE AI (opcional) ─────────────────────────────────
# Si está vacía, los embeddings se saltan (búsqueda semántica desactivada)
VOYAGE_API_KEY=

# ─── AZURE BLOB STORAGE (opcional) ───────────────────────
# Si está vacía, las fotos de productos no se suben (modo stub)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=vortex-productos

# ─── STRIPE (opcional) ────────────────────────────────────
# Si está vacía, los pagos funcionan en modo stub (no se cobra)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
